{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OBS Assessment Template",
  "description": "Human contract for OBS assessment template structure. The JS validator (assets/js/validate.js) is the enforced check.",
  "type": "object",
  "required": ["id", "version", "languages", "maturityLevels", "domains"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this template"
    },
    "version": {
      "type": "string",
      "description": "Semantic version string (e.g. '1.0.0')"
    },
    "languages": {
      "type": "array",
      "description": "Non-empty list of language codes supported by this template",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "title": {
      "type": "object",
      "description": "Localised template title — one key per language in 'languages'",
      "additionalProperties": { "type": "string" }
    },
    "description": {
      "type": "object",
      "description": "Localised template description — one key per language in 'languages'",
      "additionalProperties": { "type": "string" }
    },
    "maturityLevels": {
      "type": "array",
      "description": "Ordered maturity level definitions",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "label", "min", "max"],
        "properties": {
          "level": { "type": "integer", "description": "Numeric level index" },
          "label": {
            "type": "object",
            "description": "Localised label — one key per language in 'languages'",
            "additionalProperties": { "type": "string" }
          },
          "min": { "type": "number", "description": "Minimum score for this level" },
          "max": { "type": "number", "description": "Maximum score for this level" }
        }
      }
    },
    "domains": {
      "type": "array",
      "description": "Assessment domains, each containing questions",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "questions"],
        "properties": {
          "id": { "type": "string", "description": "Unique domain identifier" },
          "title": {
            "type": "object",
            "description": "Localised domain title — one key per language in 'languages'",
            "additionalProperties": { "type": "string" }
          },
          "customSlots": {
            "type": "integer",
            "description": "Optional number of custom question slots for this domain"
          },
          "questions": {
            "type": "array",
            "description": "Questions in this domain; all ids must be unique across the template",
            "items": {
              "type": "object",
              "required": ["id", "threatIndicator", "text", "goodPractice", "references"],
              "properties": {
                "id": { "type": "string", "description": "Globally unique question identifier" },
                "kind": { "type": "string", "description": "Question kind, e.g. 'standard'" },
                "threatIndicator": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5,
                  "description": "Threat severity indicator in range 1..5"
                },
                "weight": {
                  "type": "number",
                  "description": "Optional scoring weight; defaults apply when absent"
                },
                "critical": {
                  "type": "boolean",
                  "description": "Whether this question is marked critical"
                },
                "text": {
                  "type": "object",
                  "description": "Localised question text — one key per language in 'languages'",
                  "additionalProperties": { "type": "string" }
                },
                "goodPractice": {
                  "type": "object",
                  "description": "Localised good practice guidance — one key per language in 'languages'",
                  "additionalProperties": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "followUp": {
                  "type": "object",
                  "description": "Optional localised follow-up text — one key per language in 'languages'",
                  "additionalProperties": { "type": "string" }
                },
                "references": {
                  "type": "object",
                  "description": "Normative references (e.g. ISO 27001, NIS2, CIS controls)",
                  "properties": {
                    "iso27001": { "type": "string" },
                    "iso27002": { "type": "string" },
                    "nis2": { "type": "string" },
                    "cis": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
